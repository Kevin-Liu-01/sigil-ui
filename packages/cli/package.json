{
  "name": "@sigil-ui/cli",
  "version": "1.0.0",
  "description": "CLI for Sigil UI — project setup, preset switching, component scaffolding, token diffing, and health checks",
  "license": "MIT",
  "type": "module",
  "bin": {
    "sigil": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./config": {
      "import": {
        "types": "./dist/utils/config.d.ts",
        "default": "./dist/utils/config.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup && node ../../scripts/copy-sigil-skills.mjs .",
    "dev": "tsup --watch",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "prompts": "^2.4.2",
    "chalk": "^5.4.1",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.1",
    "@sigil-ui/tokens": "workspace:*",
    "@sigil-ui/presets": "workspace:*",
    "@sigil-ui/components": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.4",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0"
  }
}
