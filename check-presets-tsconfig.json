{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "paths": {
      "@sigil-ui/tokens": ["./packages/tokens/src/index.ts"]
    },
    "baseUrl": "."
  },
  "include": [
    "packages/presets/src/strata.ts",
    "packages/presets/src/brass.ts",
    "packages/presets/src/obsid.ts",
    "packages/presets/src/axiom.ts",
    "packages/presets/src/glyph.ts",
    "packages/presets/src/cipher.ts",
    "packages/presets/src/prism.ts",
    "packages/presets/src/helix.ts"
  ]
}
